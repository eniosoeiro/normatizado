---
import type { DiscourseSiteStats } from '../lib/discourse';
interface Props { stats: DiscourseSiteStats; }
const { stats } = Astro.props;

const hasData = stats.user_count > 0 || stats.topic_count > 0;
---

{hasData ? (
  <div class="bg-grafite grid grid-cols-4 py-7">
    {[
      { num: stats.user_count.toLocaleString('pt-BR'), label: 'Engenheiros' },
      { num: stats.topic_count.toLocaleString('pt-BR'), label: 'Discussões' },
      { num: stats.post_count.toLocaleString('pt-BR'), label: 'Respostas' },
      { num: stats.active_users_30_days.toLocaleString('pt-BR'), label: 'Ativos/mês' },
    ].map(item => (
      <div class="text-center">
        <div class="text-amber font-black text-3xl">{item.num}</div>
        <div class="text-white/50 text-xs tracking-widest uppercase mt-1">{item.label}</div>
      </div>
    ))}
  </div>
) : (
  <div class="bg-grafite py-10 px-8 text-center">
    <p class="text-amber font-black text-lg mb-1">Fórum em lançamento</p>
    <p class="text-white/50 text-sm mb-4">Seja um dos primeiros membros fundadores. Perguntas pioneiras ficam para sempre no histórico.</p>
    <a href="/cadastro" class="inline-block bg-amber text-grafite font-bold text-sm px-6 py-2.5 rounded hover:bg-yellow-400 transition-colors">
      ENTRAR NA LISTA →
    </a>
  </div>
)}
