---
import type { DiscourseThread, DiscourseUser } from '../lib/discourse';

interface Props {
  topThreads: DiscourseThread[];
  latestThreads: DiscourseThread[];
  topUsers: DiscourseUser[];
}
const { topThreads, latestThreads, topUsers } = Astro.props;

const tagColors: Record<string, string> = {
  'nr-13':        'bg-blue-light text-blue border border-blue/20',
  'nr-12':        'bg-blue-light text-blue border border-blue/20',
  'nr-10':        'bg-blue-light text-blue border border-blue/20',
  'iso-13849':    'bg-purple-50 text-purple-700 border border-purple-200',
  'asme-viii':    'bg-orange-50 text-orange-700 border border-orange-200',
  'abnt-nbr-5410':'bg-green-50 text-green-700 border border-green-200',
  'abnt-nbr-5418':'bg-green-50 text-green-700 border border-green-200',
  'nr-35':        'bg-red-50 text-red-700 border border-red-200',
};

function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
  if (diff < 3600)  return `${Math.floor(diff / 60)}min`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`;
  return `${Math.floor(diff / 86400)}d`;
}
---

<section class="px-4 md:px-8 pb-12 pt-8 max-w-6xl mx-auto">

  <!-- mobile: tags scroll + norma da semana strip (hidden on lg) -->
  <div class="lg:hidden mb-5 space-y-3">
    <!-- tags scroll -->
    <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-none -mx-1 px-1">
      {['nr-12','nr-13','asme-viii','abnt-nbr-5410','iso-13849','nr-35','laudo-tecnico'].map(tag => (
        <a href={`/forum/tag/${tag}`}
           class="flex-shrink-0 bg-blue-light text-blue text-xs font-semibold px-3 py-1.5 rounded-full border border-blue/20 hover:bg-blue hover:text-white transition-colors">
          #{tag}
        </a>
      ))}
    </div>
    <!-- norma da semana compact -->
    <a href="/forum/c/sst-e-seguranca-de-maquinas"
       class="flex items-center gap-3 bg-blue rounded-xl px-4 py-3 hover:opacity-90 transition-opacity">
      <div class="flex-1 min-w-0">
        <p class="text-amber text-[10px] font-bold tracking-widest uppercase mb-0.5">Norma da Semana</p>
        <p class="text-white/85 text-xs leading-snug line-clamp-1">O que muda no PGR 2026 com a nova revisão da NR-1?</p>
      </div>
      <span class="text-amber font-bold text-sm flex-shrink-0">→</span>
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-7">

    <!-- Feed -->
    <div>
      <!-- Tab header -->
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xl font-bold text-grafite">Tópicos em Destaque</h2>
        <div class="flex bg-gray-100 rounded-lg p-1 gap-1" role="tablist">
          <button
            id="tab-votados"
            role="tab"
            aria-selected="true"
            aria-controls="panel-votados"
            class="tab-btn px-4 py-1.5 text-xs font-bold rounded-md transition-all duration-200 bg-blue text-white shadow-sm"
            data-target="votados"
          >VOTADOS</button>
          <button
            id="tab-recentes"
            role="tab"
            aria-selected="false"
            aria-controls="panel-recentes"
            class="tab-btn px-4 py-1.5 text-xs font-bold rounded-md transition-all duration-200 text-gray-500 hover:text-grafite"
            data-target="recentes"
          >RECENTES</button>
        </div>
      </div>

      <!-- Panel: VOTADOS -->
      <div id="panel-votados" role="tabpanel" aria-labelledby="tab-votados" class="tab-panel">
        {topThreads.length === 0 ? (
          <div class="bg-white border border-border rounded-xl p-10 text-center text-gray-400 text-sm">
            Fórum em breve. Seja um dos primeiros membros!
            <br/><a href="/cadastro" class="text-blue font-semibold mt-2 inline-block">Criar conta →</a>
          </div>
        ) : (
          <>
            {topThreads.map(thread => (
              <a href={`/forum/t/${thread.slug}/${thread.id}`}
                 class="thread-card group flex gap-4 bg-white border border-border rounded-xl p-4 mb-3 hover:border-blue hover:shadow-md hover:-translate-y-px transition-all duration-200 cursor-pointer">
                <!-- vote block -->
                <div class="flex flex-col items-center gap-1 min-w-[44px]">
                  <span class="text-2xl font-black text-amber leading-none">{thread.like_count}</span>
                  <span class="text-[9px] text-gray-400 tracking-widest uppercase leading-none">votos</span>
                  {thread.posts_count > 1 && (
                    <span class="mt-1 bg-green-100 text-green-700 text-[10px] font-bold px-1.5 py-0.5 rounded-full border border-green-200">
                      ✓ {thread.posts_count - 1}
                    </span>
                  )}
                </div>
                <!-- content -->
                <div class="flex-1 min-w-0">
                  <div class="flex gap-1.5 flex-wrap mb-2">
                    {thread.tags.slice(0, 3).map(tag => (
                      <span class={`text-[9px] font-semibold px-2 py-0.5 rounded-full uppercase tracking-wide ${tagColors[tag] ?? 'bg-gray-100 text-gray-600 border border-gray-200'}`}>
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="text-sm font-semibold text-grafite leading-snug mb-1.5 group-hover:text-blue transition-colors">
                    {thread.title}
                  </h3>
                  {thread.excerpt && (
                    <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">{thread.excerpt}</p>
                  )}
                </div>
                <!-- meta -->
                <div class="hidden sm:flex flex-col items-end gap-1 ml-2 text-[11px] text-gray-400 whitespace-nowrap">
                  <span>{thread.views} views</span>
                  <span class="text-gray-300">{timeAgo(thread.created_at)}</span>
                </div>
              </a>
            ))}
            <a href="/forum/top" class="flex items-center justify-center gap-1.5 text-blue text-sm font-semibold mt-4 py-3 rounded-xl border border-dashed border-blue/30 hover:bg-blue-light transition-colors">
              Ver todos os tópicos votados →
            </a>
          </>
        )}
      </div>

      <!-- Panel: RECENTES -->
      <div id="panel-recentes" role="tabpanel" aria-labelledby="tab-recentes" class="tab-panel hidden">
        {latestThreads.length === 0 ? (
          <div class="bg-white border border-border rounded-xl p-10 text-center text-gray-400 text-sm">
            Ainda não há tópicos. <a href="/cadastro" class="text-blue font-semibold">Crie o primeiro →</a>
          </div>
        ) : (
          <>
            {latestThreads.map(thread => (
              <a href={`/forum/t/${thread.slug}/${thread.id}`}
                 class="thread-card group flex gap-4 bg-white border border-border rounded-xl p-4 mb-3 hover:border-blue hover:shadow-md hover:-translate-y-px transition-all duration-200 cursor-pointer">
                <!-- activity indicator -->
                <div class="flex flex-col items-center gap-1 min-w-[44px]">
                  <span class="text-2xl font-black text-blue leading-none">{thread.posts_count}</span>
                  <span class="text-[9px] text-gray-400 tracking-widest uppercase leading-none">resp.</span>
                  <span class="mt-1 text-[10px] text-gray-400 font-mono">{timeAgo(thread.created_at)}</span>
                </div>
                <!-- content -->
                <div class="flex-1 min-w-0">
                  <div class="flex gap-1.5 flex-wrap mb-2">
                    {thread.tags.slice(0, 3).map(tag => (
                      <span class={`text-[9px] font-semibold px-2 py-0.5 rounded-full uppercase tracking-wide ${tagColors[tag] ?? 'bg-gray-100 text-gray-600 border border-gray-200'}`}>
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="text-sm font-semibold text-grafite leading-snug mb-1.5 group-hover:text-blue transition-colors">
                    {thread.title}
                  </h3>
                  {thread.excerpt && (
                    <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">{thread.excerpt}</p>
                  )}
                </div>
                <!-- views -->
                <div class="hidden sm:flex flex-col items-end gap-1 ml-2 text-[11px] text-gray-400 whitespace-nowrap">
                  <span>{thread.views} views</span>
                  <span class="text-amber text-[10px]">❤ {thread.like_count}</span>
                </div>
              </a>
            ))}
            <a href="/forum/latest" class="flex items-center justify-center gap-1.5 text-blue text-sm font-semibold mt-4 py-3 rounded-xl border border-dashed border-blue/30 hover:bg-blue-light transition-colors">
              Ver todos os tópicos recentes →
            </a>
          </>
        )}
      </div>
    </div>

    <!-- Sidebar (desktop only) -->
    <div class="hidden lg:block">
      <!-- Top Contributors -->
      <div class="bg-white border border-border rounded-xl p-5 mb-4">
        <h3 class="text-xs font-bold text-grafite tracking-widest uppercase mb-4">Principais Colaboradores</h3>
        {topUsers.length === 0 ? (
          <p class="text-xs text-gray-400">Seja o primeiro a contribuir!</p>
        ) : (
          topUsers.map((user, i) => (
            <a href={`/forum/u/${user.username}`} class="flex items-center gap-3 mb-3 last:mb-0 group">
              <div class={`w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0
                ${i === 0 ? 'bg-blue' : i === 1 ? 'bg-green-700' : 'bg-purple-600'}`}>
                {(user.name || user.username).slice(0, 2).toUpperCase()}
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-grafite group-hover:text-blue truncate transition-colors">{user.name || user.username}</p>
                <p class="text-xs text-gray-400">{user.post_count} respostas</p>
              </div>
              <span class="text-blue text-xs font-bold">+{user.like_count}</span>
            </a>
          ))
        )}
      </div>

      <!-- Norma da Semana -->
      <div class="bg-blue rounded-xl p-5 mb-4">
        <p class="text-amber text-xs font-bold tracking-widest uppercase mb-2">Norma da Semana</p>
        <p class="text-white/85 text-sm leading-relaxed">
          Discussão aberta: o que muda no PGR para 2026 com a nova revisão da NR-1?
        </p>
        <a href="/forum/c/sst-e-seguranca-de-maquinas"
           class="block bg-amber text-grafite text-center text-xs font-bold py-2.5 rounded-lg mt-4 hover:bg-yellow-400 transition-colors">
          PARTICIPAR →
        </a>
      </div>

      <!-- Tags populares -->
      <div class="bg-white border border-border rounded-xl p-5">
        <h3 class="text-xs font-bold text-grafite tracking-widest uppercase mb-4">Tags Populares</h3>
        <div class="flex flex-wrap gap-2">
          {['nr-12','nr-13','abnt-nbr-5410','asme-viii','laudo-tecnico','nr-35','iso-13849'].map(tag => (
            <a href={`/forum/tag/${tag}`}
               class="bg-blue-light text-blue text-xs font-semibold px-3 py-1.5 rounded-full border border-blue/20 hover:bg-blue hover:text-white hover:border-blue transition-all duration-150">
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.target!;

      // update tab styles
      tabs.forEach(t => {
        const active = t.dataset.target === target;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('bg-blue', active);
        t.classList.toggle('text-white', active);
        t.classList.toggle('shadow-sm', active);
        t.classList.toggle('text-gray-500', !active);
        t.classList.toggle('hover:text-grafite', !active);
      });

      // toggle panels with fade
      panels.forEach(panel => {
        const show = panel.id === `panel-${target}`;
        if (show) {
          panel.classList.remove('hidden');
          panel.style.opacity = '0';
          requestAnimationFrame(() => {
            panel.style.transition = 'opacity 180ms ease';
            panel.style.opacity = '1';
          });
        } else {
          panel.classList.add('hidden');
          panel.style.opacity = '';
          panel.style.transition = '';
        }
      });
    });
  });
</script>
